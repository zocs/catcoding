---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '让 AI 像猫咪团队一样协作写代码' } = Astro.props;
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} — CatCoding</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <slot />
  <footer>
    <div class="container">
      <p>🐱 CatCoding — 让 AI 像猫咪团队一样协作写代码</p>
      <p style="margin-top: 8px;">
        <a href="https://github.com/catcoding-dev/catcoding">GitHub</a>
        &nbsp;·&nbsp;
        <a href="https://github.com/catcoding-dev/catcoding/blob/main/docs">Documentation</a>
        &nbsp;·&nbsp;
        <a href="https://github.com/catcoding-dev/catcoding/blob/main/LICENSE">MIT License</a>
      </p>
      <p style="margin-top: 12px; font-size: 0.8rem;">Built with 🧡 and too many cats</p>
    </div>
  </footer>
</body>
</html>
